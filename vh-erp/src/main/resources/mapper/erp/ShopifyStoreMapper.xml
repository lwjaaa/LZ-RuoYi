<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.erp.mapper.ShopifyStoreMapper">

    <resultMap id="ShopifyStoreResult" type="com.ruoyi.erp.model.domain.ShopifyStore">
        <id property="storeId" column="store_id"/>
        <result property="storeName" column="store_name"/>
        <result property="shopName" column="shop_name"/>
        <result property="apiVersion" column="api_version"/>
        <result property="apiKey" column="api_key"/>
        <result property="apiSecret" column="api_secret"/>
        <result property="accessToken" column="access_token"/>
        <result property="refreshToken" column="refresh_token"/>
        <result property="tokenExpiresAt" column="token_expires_at"/>
        <result property="baseUrl" column="base_url"/>
        <result property="isActive" column="is_active"/>
        <result property="isDefault" column="is_default"/>
        <result property="authMode" column="auth_mode"/>
        <result property="status" column="status"/>
        <result property="lastSyncTime" column="last_sync_time"/>
        <result property="syncCount" column="sync_count"/>
        <result property="remark" column="remark"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="delFlag" column="del_flag"/>
    </resultMap>

    <sql id="selectShopifyStoreVo">
        SELECT store_id, store_name, shop_name, api_version, api_key, api_secret,
               access_token, refresh_token, token_expires_at, base_url,
               is_active, is_default, auth_mode, status, last_sync_time, sync_count,
               remark, create_by, create_time, update_by, update_time, del_flag
        FROM erp_shopify_store
        WHERE del_flag = '0'
    </sql>

    <select id="selectDefaultStore" resultMap="ShopifyStoreResult">
        <include refid="selectShopifyStoreVo"/>
        AND is_default = '1' AND is_active = '1'
        LIMIT 1
    </select>

    <select id="selectActiveStores" resultMap="ShopifyStoreResult">
        <include refid="selectShopifyStoreVo"/>
        AND is_active = '1'
        ORDER BY is_default DESC, store_id ASC
    </select>

    <select id="selectByShopName" resultMap="ShopifyStoreResult">
        <include refid="selectShopifyStoreVo"/>
        AND shop_name = #{shopName}
    </select>

</mapper>