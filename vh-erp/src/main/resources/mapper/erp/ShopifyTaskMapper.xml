<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.erp.mapper.ShopifyTaskMapper">

    <resultMap type="com.ruoyi.erp.model.domain.ShopifyTask" id="ShopifyTaskResult">
        <result property="taskId" column="task_id" />
        <result property="storeId" column="store_id" />
        <result property="shopName" column="shop_name" />
        <result property="taskName" column="task_name" />
        <result property="taskType" column="task_type" />
        <result property="taskStatus" column="task_status" />
        <result property="progress" column="progress" />
        <result property="totalCount" column="total_count" />
        <result property="successCount" column="success_count" />
        <result property="partialCount" column="partial_count" />
        <result property="failedCount" column="failed_count" />
        <result property="errorMessage" column="error_message" />
        <result property="executionTime" column="execution_time" />
        <result property="startTime" column="start_time" />
        <result property="endTime" column="end_time" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="selectShopifyTaskVo">
        select task_id, store_id, shop_name, task_name, task_type, task_status, progress,
               total_count, success_count, partial_count, failed_count, error_message,
               execution_time, start_time, end_time, create_by, create_time, update_by, update_time
        from erp_shopify_task
    </sql>

    <select id="selectShopifyTaskList" parameterType="com.ruoyi.erp.model.domain.ShopifyTask" resultMap="ShopifyTaskResult">
        <include refid="selectShopifyTaskVo"/>
        <where>
            <if test="storeId != null"> and store_id = #{storeId}</if>
            <if test="shopName != null and shopName != ''"> and shop_name like concat('%', #{shopName}, '%')</if>
            <if test="taskName != null and taskName != ''"> and task_name like concat('%', #{taskName}, '%')</if>
            <if test="taskType != null and taskType != ''"> and task_type = #{taskType}</if>
            <if test="taskStatus != null and taskStatus != ''"> and task_status = #{taskStatus}</if>
            <if test="params != null and params.beginStartTime != null and params.beginStartTime != '' and params.endStartTime != null and params.endStartTime != ''">
                and DATE_FORMAT(start_time, '%Y-%m-%d') between #{params.beginStartTime} and #{params.endStartTime}
            </if>
        </where>
        order by create_time desc
    </select>

    <select id="selectShopifyTaskByTaskId" parameterType="Long" resultMap="ShopifyTaskResult">
        <include refid="selectShopifyTaskVo"/>
        where task_id = #{taskId}
    </select>

    <insert id="insertShopifyTask" parameterType="com.ruoyi.erp.model.domain.ShopifyTask">
        insert into erp_shopify_task
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="taskId != null">task_id,</if>
            <if test="storeId != null">store_id,</if>
            <if test="shopName != null and shopName != ''">shop_name,</if>
            <if test="taskName != null and taskName != ''">task_name,</if>
            <if test="taskType != null and taskType != ''">task_type,</if>
            <if test="taskStatus != null">task_status,</if>
            <if test="progress != null">progress,</if>
            <if test="totalCount != null">total_count,</if>
            <if test="successCount != null">success_count,</if>
            <if test="partialCount != null">partial_count,</if>
            <if test="failedCount != null">failed_count,</if>
            <if test="errorMessage != null">error_message,</if>
            <if test="executionTime != null">execution_time,</if>
            <if test="startTime != null">start_time,</if>
            <if test="endTime != null">end_time,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="taskId != null">#{taskId},</if>
            <if test="storeId != null">#{storeId},</if>
            <if test="shopName != null and shopName != ''">#{shopName},</if>
            <if test="taskName != null and taskName != ''">#{taskName},</if>
            <if test="taskType != null and taskType != ''">#{taskType},</if>
            <if test="taskStatus != null">#{taskStatus},</if>
            <if test="progress != null">#{progress},</if>
            <if test="totalCount != null">#{totalCount},</if>
            <if test="successCount != null">#{successCount},</if>
            <if test="partialCount != null">#{partialCount},</if>
            <if test="failedCount != null">#{failedCount},</if>
            <if test="errorMessage != null">#{errorMessage},</if>
            <if test="executionTime != null">#{executionTime},</if>
            <if test="startTime != null">#{startTime},</if>
            <if test="endTime != null">#{endTime},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateShopifyTask" parameterType="com.ruoyi.erp.model.domain.ShopifyTask">
        update erp_shopify_task
        <trim prefix="SET" suffixOverrides=",">
            <if test="storeId != null">store_id = #{storeId},</if>
            <if test="shopName != null and shopName != ''">shop_name = #{shopName},</if>
            <if test="taskName != null and taskName != ''">task_name = #{taskName},</if>
            <if test="taskType != null and taskType != ''">task_type = #{taskType},</if>
            <if test="taskStatus != null">task_status = #{taskStatus},</if>
            <if test="progress != null">progress = #{progress},</if>
            <if test="totalCount != null">total_count = #{totalCount},</if>
            <if test="successCount != null">success_count = #{successCount},</if>
            <if test="partialCount != null">partial_count = #{partialCount},</if>
            <if test="failedCount != null">failed_count = #{failedCount},</if>
            <if test="errorMessage != null">error_message = #{errorMessage},</if>
            <if test="executionTime != null">execution_time = #{executionTime},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where task_id = #{taskId}
    </update>

    <delete id="deleteShopifyTaskByTaskId" parameterType="Long">
        delete from erp_shopify_task where task_id = #{taskId}
    </delete>

    <delete id="deleteShopifyTaskByTaskIds" parameterType="String">
        delete from erp_shopify_task where task_id in
        <foreach item="taskId" collection="array" open="(" separator="," close=")">
            #{taskId}
        </foreach>
    </delete>
</mapper>
